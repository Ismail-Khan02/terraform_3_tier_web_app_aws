aws_region         = "us-east-1"
environment        = "dev"
availability_zones = ["us-east-1a", "us-east-1b"]

vpc_cidr                 = "10.0.0.0/16"
public_subnet_cidrs      = ["10.0.1.0/24", "10.0.2.0/24"]
web_subnet_cidrs         = ["10.0.3.0/24", "10.0.4.0/24"]
application_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]

instance_type = "t3.micro"
# ec2_ami     = "ami-xxxxxxxxxxxxxxxxx"  # Omit to use latest Amazon Linux 2

web_asg_min_size         = 2
web_asg_desired_capacity = 2
web_asg_max_size         = 4

app_asg_min_size         = 2
app_asg_desired_capacity = 2
app_asg_max_size         = 4

db_username             = "admin"
db_name                 = "mydb"
skip_final_snapshot     = true   # Set to false for prod
backup_retention_period = 7
# db_password is intentionally omitted — set via: export TF_VAR_db_password="..."

deletion_protection = false      # Set to true for prod
# certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/..."  # Required for HTTPS

alert_email = "your-email@example.com"
